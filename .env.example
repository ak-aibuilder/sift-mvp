# Copy to .env.local and fill in. .env.local is gitignored.

# -- LLM (OpenAI-compatible /v1/chat/completions; works with Groq, Together, Ollama, etc.) --
# Swap providers by changing only these three vars — no code change.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.1-8b-instant

# -- Embedding model (local via @huggingface/transformers; no API key, downloads ~80MB on first run) --
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# -- Database (SQLite file; created by the seed script if missing) --
DATABASE_PATH=./data/sift.db
